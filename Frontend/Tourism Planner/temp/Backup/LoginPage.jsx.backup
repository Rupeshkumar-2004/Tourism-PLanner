/*
  ╔══════════════════════════════════════════════════════════════════╗
  ║  📘 LESSON: React Forms — Controlled Components                  ║
  ╠══════════════════════════════════════════════════════════════════╣
  ║                                                                  ║
  ║  In React, there are TWO ways to handle form inputs:             ║
  ║                                                                  ║
  ║  1. UNCONTROLLED (DOM handles the value):                        ║
  ║     const inputRef = useRef();                                   ║
  ║     <input ref={inputRef} />                                     ║
  ║     // Get value: inputRef.current.value                         ║
  ║                                                                  ║
  ║  2. CONTROLLED (React handles the value): ← We use this         ║
  ║     const [email, setEmail] = useState('');                      ║
  ║     <input value={email} onChange={e => setEmail(e.target.value)}/> ║
  ║                                                                  ║
  ║  WHY controlled?                                                 ║
  ║  - React is the "single source of truth"                         ║
  ║  - You can validate on every keystroke                           ║
  ║  - You can transform input (trim, lowercase, etc.)              ║
  ║  - Easier to test and debug                                      ║
  ║                                                                  ║
  ║  The pattern is always:                                          ║
  ║  1. Create state: const [value, setValue] = useState('')         ║
  ║  2. Bind to input: value={value}                                ║
  ║  3. Handle changes: onChange={e => setValue(e.target.value)}     ║
  ║                                                                  ║
  ║  🎯 INTERNSHIP TIP: "What's a controlled component?"            ║
  ║  Answer: A form element whose value is driven by React state,   ║
  ║  not by the DOM. React controls the input, not the browser.     ║
  ╚══════════════════════════════════════════════════════════════════╝
*/

import { useState } from 'react';
import { Link, useNavigate } from 'react-router-dom';
import { useAuth } from '../hooks/useAuth.js';

// 📘 Lucide-react gives us beautiful SVG icons as React components.
// Each icon is imported by name. They accept className for styling.
import { Mail, Lock, Eye, EyeOff, Plane, ArrowRight } from 'lucide-react';

export default function LoginPage() {

  // ─── State ──────────────────────────────────────────────────────
  // 📘 Each form field gets its own state variable.
  // When the user types, React re-renders with the new value.
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [showPassword, setShowPassword] = useState(false); // Toggle password visibility
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [formError, setFormError] = useState('');

  // 📘 useNavigate() — React Router's hook for programmatic navigation.
  // Instead of <Link to="/dashboard">, which is a clickable element,
  // navigate('/dashboard') lets you redirect AFTER an async operation (like login).
  const navigate = useNavigate();

  // 📘 Destructuring from our custom hook — gets auth functions from Context.
  // We could also get `user`, `isAuthenticated`, etc. if needed.
  const { login } = useAuth();

  // ─── Form Submit Handler ────────────────────────────────────────
  /*
    📘 LESSON: Form Submission in React

    When a <form> has onSubmit={handleSubmit}:
    1. Browser fires the submit event when the user presses Enter or clicks the submit button
    2. We call e.preventDefault() to STOP the browser from refreshing the page
       (default HTML behavior is to reload — we don't want that in a React SPA!)
    3. We gather the state values and call our API

    The async/await pattern:
    - `async` marks a function as asynchronous (it returns a Promise)
    - `await` pauses execution until the Promise resolves
    - try/catch handles errors from the await
    - finally runs no matter what (success or error)
  */
  const handleSubmit = async (e) => {
    e.preventDefault(); // 📘 CRITICAL: prevents page reload
    setFormError('');
    setIsSubmitting(true);

    try {
      // 📘 Call the login function from AuthContext.
      // It calls the API, sets user in context, and returns the response.
      await login({ email, password });

      // 📘 If login succeeds (no error thrown), redirect to dashboard.
      navigate('/dashboard');
    } catch (err) {
      // 📘 The error message comes from our AuthContext,
      // which gets it from the backend's ApiError.
      setFormError(
        err.response?.data?.message || 'Something went wrong. Please try again.'
      );
    } finally {
      setIsSubmitting(false);
    }
  };

  // ─── JSX (The UI) ──────────────────────────────────────────────
  /*
    📘 LESSON: JSX — JavaScript XML

    JSX looks like HTML but it's actually JavaScript.
    Key differences from HTML:
    1. className instead of class (class is a JS reserved word)
    2. htmlFor instead of for
    3. camelCase for attributes: onClick, onChange, onSubmit
    4. Self-closing tags: <input /> not <input>
    5. Expressions in curly braces: {email}, {isSubmitting ? 'Loading' : 'Submit'}
    6. Conditional rendering: {error && <p>{error}</p>}
  */
  return (
    <div className="min-h-screen flex">
      {/* ─── Left Panel: Branding ──────────────────────────────── */}
      <div className="hidden lg:flex lg:w-1/2 relative overflow-hidden">
        {/* Background gradient */}
        <div className="absolute inset-0 bg-gradient-to-br from-sky-400 via-sky-500 to-blue-600"></div>
        
        {/* Decorative blurred circles */}
        <div className="absolute top-20 left-20 w-72 h-72 bg-white/10 rounded-full blur-3xl"></div>
        <div className="absolute bottom-20 right-20 w-96 h-96 bg-sky-300/20 rounded-full blur-3xl"></div>

        {/* Content */}
        <div className="relative z-10 flex flex-col justify-center p-16 text-white">
          <div className="flex items-center gap-3 mb-12">
            <div className="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center">
              <Plane className="w-6 h-6" />
            </div>
            <span className="text-2xl font-bold">SkyVoyage</span>
          </div>
          
          <h1 className="text-5xl font-bold leading-tight mb-6">
            Plan your dream<br />
            <span className="text-sky-200">adventure</span> today
          </h1>
          
          <p className="text-lg text-sky-100 max-w-md leading-relaxed">
            Discover breathtaking destinations, create detailed itineraries, 
            and manage your travel budget — all in one place.
          </p>

          <div className="mt-12 flex items-center gap-4">
            <div className="flex -space-x-3">
              {[1, 2, 3, 4].map(i => (
                <div key={i} className="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border-2 border-white/30 flex items-center justify-center text-xs font-bold">
                  {String.fromCharCode(64 + i)}
                </div>
              ))}
            </div>
            <p className="text-sm text-sky-100">Join 50,000+ happy travelers</p>
          </div>
        </div>
      </div>

      {/* ─── Right Panel: Login Form ───────────────────────────── */}
      <div className="w-full lg:w-1/2 flex items-center justify-center p-8 bg-slate-50">
        <div className="w-full max-w-md">
          {/* Mobile logo (hidden on desktop) */}
          <div className="lg:hidden flex items-center gap-2 mb-8">
            <div className="w-10 h-10 bg-gradient-to-br from-sky-400 to-sky-500 rounded-xl flex items-center justify-center">
              <Plane className="w-5 h-5 text-white" />
            </div>
            <span className="text-xl font-bold text-slate-800">SkyVoyage</span>
          </div>

          <h2 className="text-3xl font-bold text-slate-800 mb-2">Welcome back</h2>
          <p className="text-slate-500 mb-8">Enter your credentials to access your account</p>

          {/* ─── Error Display ─────────────────────────────────── */}
          {/* 
            📘 Conditional Rendering — {condition && <JSX>}
            
            This is a short-circuit evaluation:
            - If formError is "" (falsy) → nothing renders
            - If formError has text (truthy) → the <div> renders
            
            Alternative syntax: {formError ? <ErrorDiv /> : null}
          */}
          {formError && (
            <div className="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 text-sm">
              {formError}
            </div>
          )}

          {/* ─── The Form ──────────────────────────────────────── */}
          {/* 
            📘 onSubmit on <form> catches:
            - Button clicks on type="submit" buttons
            - Enter key presses in any input field
            Both trigger our handleSubmit function.
          */}
          <form onSubmit={handleSubmit} className="space-y-5">
            
            {/* Email Field */}
            <div>
              <label htmlFor="email" className="block text-sm font-medium text-slate-700 mb-2">
                Email Address
              </label>
              <div className="relative">
                {/* 📘 The icon is positioned absolutely inside the input's container */}
                <Mail className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" />
                <input
                  id="email"
                  type="email"
                  placeholder="Enter your email"
                  value={email}                                    // 📘 Controlled: value comes from state
                  onChange={(e) => setEmail(e.target.value)}        // 📘 On every keystroke, update state
                  required                                          // HTML5 validation
                  className="w-full pl-12 pr-4 py-3.5 bg-white border border-slate-200 rounded-xl
                             text-slate-800 placeholder-slate-400
                             focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500
                             transition-all duration-200"
                />
              </div>
            </div>

            {/* Password Field */}
            <div>
              <label htmlFor="password" className="block text-sm font-medium text-slate-700 mb-2">
                Password
              </label>
              <div className="relative">
                <Lock className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" />
                <input
                  id="password"
                  type={showPassword ? 'text' : 'password'}        // 📘 Dynamic type based on state!
                  placeholder="Enter your password"
                  value={password}
                  onChange={(e) => setPassword(e.target.value)}
                  required
                  className="w-full pl-12 pr-12 py-3.5 bg-white border border-slate-200 rounded-xl
                             text-slate-800 placeholder-slate-400
                             focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500
                             transition-all duration-200"
                />
                {/*
                  📘 Toggle button for password visibility.
                  onClick calls the setter with the opposite boolean value.
                  This is a common pattern: setX(!x) to toggle.
                */}
                <button
                  type="button"                                     // 📘 type="button" prevents form submission!
                  onClick={() => setShowPassword(!showPassword)}
                  className="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600"
                >
                  {showPassword ? <EyeOff className="w-5 h-5" /> : <Eye className="w-5 h-5" />}
                </button>
              </div>
            </div>

            {/* Submit Button */}
            <button
              type="submit"
              disabled={isSubmitting}                              // 📘 Disabled while API call is in progress
              className="w-full py-3.5 bg-gradient-to-r from-sky-500 to-blue-500 text-white font-semibold
                         rounded-xl flex items-center justify-center gap-2
                         hover:from-sky-600 hover:to-blue-600
                         disabled:opacity-50 disabled:cursor-not-allowed
                         transition-all duration-200 shadow-lg shadow-sky-500/25"
            >
              {/*
                📘 Ternary operator in JSX — {condition ? <A/> : <B/>}
                Shows different content based on loading state.
              */}
              {isSubmitting ? (
                <div className="animate-spin rounded-full h-5 w-5 border-2 border-white border-t-transparent"></div>
              ) : (
                <>
                  Sign In
                  <ArrowRight className="w-5 h-5" />
                </>
              )}
            </button>
          </form>

          {/* ─── Register Link ─────────────────────────────────── */}
          {/*
            📘 <Link> from React Router — like <a> but doesn't reload the page.
            Regular <a> causes a full page reload (browser fetches everything again).
            <Link> just updates the URL and React renders the new component.
            This is what makes React a "Single Page Application" (SPA).
          */}
          <p className="mt-8 text-center text-slate-500">
            Don't have an account?{' '}
            <Link to="/register" className="text-sky-500 font-semibold hover:text-sky-600 transition-colors">
              Create Account
            </Link>
          </p>
        </div>
      </div>
    </div>
  );
}
