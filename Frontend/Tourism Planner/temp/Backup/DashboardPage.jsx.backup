/*
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  📘 LESSON: useEffect for Data Fetching + Rendering Lists          ║
  ╠══════════════════════════════════════════════════════════════════════╣
  ║                                                                      ║
  ║  This page teaches:                                                  ║
  ║  1. useEffect — fetching data when the component loads               ║
  ║  2. Loading / Error / Empty states — the 3 states every list has     ║
  ║  3. .map() — rendering arrays of data as UI elements                 ║
  ║  4. Lifting state up — child component tells parent to delete        ║
  ║  5. Modal pattern — showing a form in an overlay                     ║
  ║                                                                      ║
  ║  🎯 INTERNSHIP TIP: "How do you fetch data in React?"               ║
  ║  Answer: useEffect with an async function inside it.                 ║
  ║  You CANNOT make useEffect itself async — you create an async        ║
  ║  function inside it and call it immediately (IIFE pattern).          ║
  ╚══════════════════════════════════════════════════════════════════════╝
*/

import { useState, useEffect } from 'react';
import { useAuth } from '../hooks/useAuth.js';
import { Link } from 'react-router-dom';
import * as tripService from '../services/tripService.js';
import { 
  Plus, MapPin, Calendar, Wallet, Trash2, Edit3, 
  Plane, LogOut, Search, Map, ChevronRight, X 
} from 'lucide-react';

export default function DashboardPage() {
  const { user, logout } = useAuth();

  // ─── State ──────────────────────────────────────────────────────
  /*
    📘 THE THREE STATES OF DATA FETCHING

    Every component that fetches data needs these three states:
    1. isLoading (true while fetching)
    2. error (set if fetch fails)
    3. data (the actual data, empty by default)

    UI shows different things for each:
    - Loading → spinner
    - Error → error message + retry button
    - Data empty → "No trips yet" empty state
    - Data exists → the actual list
  */
  const [trips, setTrips] = useState([]);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState(null);
  const [showCreateModal, setShowCreateModal] = useState(false);

  // ─── Fetch trips on mount ───────────────────────────────────────
  /*
    📘 WHY useEffect for fetching?

    React components are FUNCTIONS. They run every time state changes.
    If you put a fetch call directly in the function body:

      function Dashboard() {
        fetch('/api/trips'); // ❌ This runs on EVERY render!
      }

    useEffect controls WHEN the code runs:
      useEffect(() => { fetch(...) }, []); // ✅ Runs only ONCE on mount

    📘 WHY not make useEffect async directly?

    ❌ WRONG:
      useEffect(async () => { await fetch(...) }, []);
    
    useEffect must return undefined or a cleanup function.
    async functions return a Promise, which breaks this contract.

    ✅ CORRECT:
      useEffect(() => {
        const fetchData = async () => { await fetch(...) };
        fetchData(); // Call immediately
      }, []);
  */
  useEffect(() => {
    const fetchTrips = async () => {
      setIsLoading(true);
      try {
        const response = await tripService.getUserTrips();
        // response.data = { trips: [...], pagination: {...} }
        setTrips(response.data.trips);
      } catch (err) {
        setError('Failed to load trips. Please try again.');
        console.error(err);
      } finally {
        setIsLoading(false);
      }
    };

    fetchTrips();
  }, []); // 📘 Empty array = run once when component mounts

  // ─── Delete a trip ──────────────────────────────────────────────
  /*
    📘 LESSON: Optimistic vs Pessimistic Updates

    PESSIMISTIC (what we use here):
    1. Call API to delete
    2. Wait for success
    3. THEN update the UI
    Safer but slower.

    OPTIMISTIC:
    1. Update UI immediately
    2. Call API in background
    3. If API fails, UNDO the UI change
    Faster but more complex.
  */
  const handleDeleteTrip = async (tripId) => {
    if (!window.confirm('Are you sure you want to delete this trip?')) return;

    try {
      await tripService.deleteTrip(tripId);
      // 📘 .filter() creates a NEW array without the deleted trip.
      // React detects the new array reference and re-renders the list.
      // We DON'T mutate the original array — React needs new references
      // to trigger re-renders.
      setTrips(trips.filter(trip => trip._id !== tripId));
    } catch (err) {
      alert('Failed to delete trip. Please try again.');
    }
  };

  // ─── Create trip handler ────────────────────────────────────────
  const handleTripCreated = (newTrip) => {
    // 📘 Spread operator to add new trip to the beginning of the array.
    // [newTrip, ...trips] = new trip first, then all existing trips.
    setTrips([newTrip, ...trips]);
    setShowCreateModal(false);
  };

  // ─── Format date helper ─────────────────────────────────────────
  const formatDate = (dateStr) => {
    return new Date(dateStr).toLocaleDateString('en-IN', {
      day: 'numeric', month: 'short', year: 'numeric'
    });
  };

  // ─── Render ─────────────────────────────────────────────────────
  return (
    <div className="min-h-screen bg-slate-50">
      {/* ─── Top Navbar ────────────────────────────────────────── */}
      <nav className="bg-white border-b border-slate-200 px-6 py-4 sticky top-0 z-50">
        <div className="max-w-7xl mx-auto flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-gradient-to-br from-sky-400 to-sky-500 rounded-xl flex items-center justify-center">
              <Plane className="w-5 h-5 text-white" />
            </div>
            <span className="text-xl font-bold text-slate-800">SkyVoyage</span>
          </div>

          <div className="flex items-center gap-6">
            <Link to="/destinations" className="text-slate-600 hover:text-sky-500 font-medium transition-colors flex items-center gap-1.5">
              <Map className="w-4 h-4" />
              Destinations
            </Link>
            <div className="flex items-center gap-3">
              <div className="w-9 h-9 rounded-full bg-gradient-to-br from-sky-400 to-blue-500 flex items-center justify-center text-white text-sm font-bold">
                {user?.fullName?.charAt(0)?.toUpperCase() || 'U'}
              </div>
              <button
                onClick={logout}
                className="text-slate-400 hover:text-red-500 transition-colors"
                title="Logout"
              >
                <LogOut className="w-5 h-5" />
              </button>
            </div>
          </div>
        </div>
      </nav>

      <div className="max-w-7xl mx-auto px-6 py-8">
        {/* ─── Welcome Section ───────────────────────────────────── */}
        <div className="mb-8">
          <h1 className="text-3xl font-bold text-slate-800">
            Welcome back, <span className="text-sky-500">{user?.fullName?.split(' ')[0] || 'Traveler'}</span> 👋
          </h1>
          <p className="text-slate-500 mt-1">Here's an overview of your travel plans</p>
        </div>

        {/* ─── Stats Cards ───────────────────────────────────────── */}
        {/*
          📘 .map() — The most important React pattern for lists.
          
          .map() transforms each item in an array into a JSX element.
          React then renders all of them.

          The `key` prop is REQUIRED. React uses it to efficiently
          track which items changed/added/removed when the list updates.

          Rules for keys:
          - Must be unique among siblings
          - Should be stable (don't use array index if items can reorder)
          - Database IDs are perfect keys
        */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
          {[
            { 
              label: 'Total Trips', 
              value: trips.length, 
              icon: <MapPin className="w-5 h-5" />,
              color: 'from-sky-400 to-sky-500'
            },
            { 
              label: 'Total Budget', 
              value: `₹${trips.reduce((sum, t) => sum + (t.totalBudget || 0), 0).toLocaleString()}`,
              icon: <Wallet className="w-5 h-5" />,
              color: 'from-emerald-400 to-emerald-500'
            },
            { 
              label: 'Upcoming Trips', 
              value: trips.filter(t => new Date(t.startDate) > new Date()).length,
              icon: <Calendar className="w-5 h-5" />,
              color: 'from-violet-400 to-violet-500'
            },
          ].map((stat) => (
            <div key={stat.label} className="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-slate-500 mb-1">{stat.label}</p>
                  <p className="text-2xl font-bold text-slate-800">{stat.value}</p>
                </div>
                <div className={`w-12 h-12 rounded-xl bg-gradient-to-br ${stat.color} flex items-center justify-center text-white`}>
                  {stat.icon}
                </div>
              </div>
            </div>
          ))}
        </div>

        {/* ─── My Trips Section ──────────────────────────────────── */}
        <div className="flex items-center justify-between mb-6">
          <h2 className="text-xl font-bold text-slate-800">My Trips</h2>
          <button
            onClick={() => setShowCreateModal(true)}
            className="px-5 py-2.5 bg-gradient-to-r from-sky-500 to-blue-500 text-white font-medium
                       rounded-xl flex items-center gap-2
                       hover:from-sky-600 hover:to-blue-600
                       transition-all duration-200 shadow-md shadow-sky-500/20"
          >
            <Plus className="w-5 h-5" />
            New Trip
          </button>
        </div>

        {/* ─── CONDITIONAL RENDERING: Loading / Error / Empty / List ─ */}
        {/*
          📘 This is the "state machine" pattern for data display.
          Every data-fetching component should handle ALL these states:
        */}
        {isLoading ? (
          // State 1: Loading
          <div className="flex flex-col items-center justify-center py-20">
            <div className="animate-spin rounded-full h-12 w-12 border-4 border-sky-500 border-t-transparent mb-4"></div>
            <p className="text-slate-500">Loading your trips...</p>
          </div>
        ) : error ? (
          // State 2: Error
          <div className="text-center py-20">
            <p className="text-red-500 mb-4">{error}</p>
            <button
              onClick={() => window.location.reload()}
              className="px-4 py-2 bg-sky-500 text-white rounded-lg"
            >
              Retry
            </button>
          </div>
        ) : trips.length === 0 ? (
          // State 3: Empty
          <div className="text-center py-20 bg-white rounded-2xl border border-slate-100">
            <div className="w-20 h-20 bg-sky-50 rounded-full flex items-center justify-center mx-auto mb-4">
              <MapPin className="w-10 h-10 text-sky-400" />
            </div>
            <h3 className="text-xl font-semibold text-slate-700 mb-2">No trips yet</h3>
            <p className="text-slate-500 mb-6">Start planning your first adventure!</p>
            <button
              onClick={() => setShowCreateModal(true)}
              className="px-6 py-3 bg-gradient-to-r from-sky-500 to-blue-500 text-white font-medium rounded-xl"
            >
              Create Your First Trip
            </button>
          </div>
        ) : (
          // State 4: Data exists — render the list!
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {/*
              📘 .map() — Loop through trips array and render a card for each.
              
              IMPORTANT: Always provide a unique `key` prop.
              trip._id comes from MongoDB — guaranteed unique.
            */}
            {trips.map((trip) => (
              <div
                key={trip._id}
                className="bg-white rounded-2xl border border-slate-100 overflow-hidden
                           hover:shadow-lg hover:border-sky-100 transition-all duration-300 group"
              >
                {/* Card header with gradient */}
                <div className="h-3 bg-gradient-to-r from-sky-400 to-blue-500"></div>
                
                <div className="p-6">
                  <div className="flex items-start justify-between mb-3">
                    <h3 className="text-lg font-semibold text-slate-800 group-hover:text-sky-600 transition-colors">
                      {trip.title}
                    </h3>
                    <div className="flex gap-1">
                      <button
                        onClick={() => handleDeleteTrip(trip._id)}
                        className="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors"
                        title="Delete trip"
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </div>
                  </div>

                  {trip.description && (
                    <p className="text-sm text-slate-500 mb-4 line-clamp-2">{trip.description}</p>
                  )}

                  <div className="space-y-2 mb-4">
                    <div className="flex items-center gap-2 text-sm text-slate-600">
                      <Calendar className="w-4 h-4 text-sky-500" />
                      {formatDate(trip.startDate)} — {formatDate(trip.endDate)}
                    </div>
                    <div className="flex items-center gap-2 text-sm text-slate-600">
                      <Wallet className="w-4 h-4 text-emerald-500" />
                      ₹{trip.totalBudget?.toLocaleString()}
                    </div>
                  </div>

                  <Link
                    to={`/trips/${trip._id}`}
                    className="flex items-center gap-1 text-sm font-medium text-sky-500 hover:text-sky-600 transition-colors"
                  >
                    View Details
                    <ChevronRight className="w-4 h-4" />
                  </Link>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      {/* ─── Create Trip Modal ─────────────────────────────────── */}
      {/*
        📘 LESSON: Modal Pattern

        A modal is shown/hidden using a boolean state (showCreateModal).
        When true, we render the modal JSX. When false, nothing renders.

        The modal has:
        1. A backdrop (semi-transparent dark background)
        2. A card (the actual form)
        3. A way to close (X button + clicking backdrop)
      */}
      {showCreateModal && (
        <CreateTripModal
          onClose={() => setShowCreateModal(false)}
          onCreated={handleTripCreated}
        />
      )}
    </div>
  );
}


/*
  ╔══════════════════════════════════════════════════════════════════╗
  ║  📘 LESSON: Component Composition — Breaking UI into pieces     ║
  ╠══════════════════════════════════════════════════════════════════╣
  ║                                                                  ║
  ║  The CreateTripModal is a CHILD component of DashboardPage.      ║
  ║                                                                  ║
  ║  Communication pattern:                                          ║
  ║  Parent → Child: via PROPS (onClose, onCreated)                  ║
  ║  Child → Parent: by CALLING the prop functions                   ║
  ║                                                                  ║
  ║  This is called "lifting state up" — the parent owns the state,  ║
  ║  and passes callbacks to children so they can request changes.   ║
  ║                                                                  ║
  ║  🎯 INTERNSHIP TIP: "How do child components communicate with   ║
  ║  parent?" → "By calling callback functions passed as props."     ║
  ╚══════════════════════════════════════════════════════════════════╝
*/
function CreateTripModal({ onClose, onCreated }) {
  const [form, setForm] = useState({
    title: '',
    description: '',
    startDate: '',
    endDate: '',
    totalBudget: '',
  });
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [error, setError] = useState('');

  const handleChange = (e) => {
    setForm({ ...form, [e.target.name]: e.target.value });
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    setIsSubmitting(true);
    setError('');

    try {
      const response = await tripService.createTrip({
        title: form.title,
        description: form.description,
        startDate: form.startDate,
        endDate: form.endDate,
        totalBudget: Number(form.totalBudget),
      });

      // 📘 Call the parent's callback with the new trip data.
      // The parent will add it to the trips array and close the modal.
      onCreated(response.data);
    } catch (err) {
      setError(err.response?.data?.message || 'Failed to create trip');
    } finally {
      setIsSubmitting(false);
    }
  };

  return (
    // 📘 Backdrop — clicking it closes the modal
    <div className="fixed inset-0 z-50 flex items-center justify-center p-4">
      <div className="absolute inset-0 bg-black/50 backdrop-blur-sm" onClick={onClose}></div>
      
      {/* Modal card */}
      <div className="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg p-8">
        <div className="flex items-center justify-between mb-6">
          <h2 className="text-2xl font-bold text-slate-800">Create New Trip</h2>
          <button onClick={onClose} className="p-2 text-slate-400 hover:text-slate-600 rounded-lg hover:bg-slate-100">
            <X className="w-5 h-5" />
          </button>
        </div>

        {error && (
          <div className="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-red-600 text-sm">{error}</div>
        )}

        <form onSubmit={handleSubmit} className="space-y-4">
          <div>
            <label className="block text-sm font-medium text-slate-700 mb-1.5">Trip Title</label>
            <input
              name="title"
              placeholder="e.g., Goa Beach Vacation"
              value={form.title}
              onChange={handleChange}
              required
              className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl
                         text-slate-800 placeholder-slate-400
                         focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-slate-700 mb-1.5">Description</label>
            <textarea
              name="description"
              placeholder="What's this trip about?"
              value={form.description}
              onChange={handleChange}
              rows={3}
              className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl
                         text-slate-800 placeholder-slate-400 resize-none
                         focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500"
            />
          </div>

          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-slate-700 mb-1.5">Start Date</label>
              <input
                name="startDate"
                type="date"
                value={form.startDate}
                onChange={handleChange}
                required
                className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-800
                           focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-slate-700 mb-1.5">End Date</label>
              <input
                name="endDate"
                type="date"
                value={form.endDate}
                onChange={handleChange}
                required
                className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-800
                           focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500"
              />
            </div>
          </div>

          <div>
            <label className="block text-sm font-medium text-slate-700 mb-1.5">Total Budget (₹)</label>
            <input
              name="totalBudget"
              type="number"
              min="0"
              placeholder="e.g., 25000"
              value={form.totalBudget}
              onChange={handleChange}
              required
              className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-800
                         focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500"
            />
          </div>

          <button
            type="submit"
            disabled={isSubmitting}
            className="w-full py-3.5 bg-gradient-to-r from-sky-500 to-blue-500 text-white font-semibold
                       rounded-xl flex items-center justify-center gap-2
                       hover:from-sky-600 hover:to-blue-600
                       disabled:opacity-50 disabled:cursor-not-allowed
                       transition-all shadow-lg shadow-sky-500/25"
          >
            {isSubmitting ? (
              <div className="animate-spin rounded-full h-5 w-5 border-2 border-white border-t-transparent"></div>
            ) : (
              <>
                <Plus className="w-5 h-5" />
                Create Trip
              </>
            )}
          </button>
        </form>
      </div>
    </div>
  );
}
