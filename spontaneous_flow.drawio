        <mxCell id="e2" value="!parsed.success" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#555555;fontColor=#b85450;" edge="1" parent="1" source="n_parse" target="n_400">
