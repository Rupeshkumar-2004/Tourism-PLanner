  <diagram id="spontaneous-backend-flow" name="Spontaneous Backend Code Flow">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" adaptiveColors="auto" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Header Title -->
        <mxCell id="title" value="SPONTANEOUS CONTROLLER: BACKEND LOGICAL FLOW" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=18;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="327" y="30" width="1000" height="40" as="geometry" />
        </mxCell>
        
        <!-- 1. Start Node -->
        <mxCell id="n_start" value="GET /spontaneous&lt;br&gt;&lt;b&gt;Receives:&lt;/b&gt; req.query" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="550" y="125" width="100" height="70" as="geometry" />
        </mxCell>
        
        <!-- 2. Validation -->
        <mxCell id="n_parse" value="spontaneousQuerySchema&lt;br&gt;.safeParse(req.query)&lt;br&gt;&lt;b&gt;Validates:&lt;/b&gt; lat, lon" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="530" y="260" width="140" height="100" as="geometry" />
        </mxCell>
        
        <!-- Error 400 -->
        <mxCell id="n_400" value="&lt;b&gt;throw ApiError(400)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Sends:&lt;/b&gt; Validation Errors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 3. Get City -->
        <mxCell id="n_city" value="getCityFromCoordinates()&lt;br&gt;&lt;br&gt;&lt;b&gt;In:&lt;/b&gt; lat, lon&lt;br&gt;&lt;b&gt;Out:&lt;/b&gt; city, state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="420" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 4. Get Weather -->
        <mxCell id="n_weather" value="getWeatherForCoordinates()&lt;br&gt;&lt;br&gt;&lt;b&gt;In:&lt;/b&gt; lat, lon&lt;br&gt;&lt;b&gt;Out:&lt;/b&gt; temp, condition, icon" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="420" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- Catch Block -->
        <mxCell id="n_catch" value="try/catch fallback&lt;br&gt;&lt;br&gt;&lt;b&gt;Action:&lt;/b&gt; weather = null&lt;br&gt;&lt;i&gt;(Execution Continues)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="420" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 5. Get Places -->
        <mxCell id="n_places" value="getTouristPlacesByCoords()&lt;br&gt;&lt;br&gt;&lt;b&gt;In:&lt;/b&gt; lat, lon, radius=20&lt;br&gt;&lt;b&gt;Out:&lt;/b&gt; places array" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="570" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 6. AI Processing -->
        <mxCell id="n_ai" value="generateSpontaneous&lt;br&gt;Itineraries()&lt;br&gt;&lt;b&gt;In:&lt;/b&gt; places, city&lt;br&gt;&lt;b&gt;Out:&lt;/b&gt; suggestions, paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="570" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 7. Image Fetching -->
        <mxCell id="n_img" value="getPexelsImageForPlace()&lt;br&gt;[Concurrent Promise.all]&lt;br&gt;&lt;b&gt;In:&lt;/b&gt; titles, city&lt;br&gt;&lt;b&gt;Out:&lt;/b&gt; image URLs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="720" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 8. Map Gen -->
        <mxCell id="n_map" value="getStaticMapUrl()&lt;br&gt;&lt;br&gt;&lt;b&gt;In:&lt;/b&gt; lat, lon, mapMarkers&lt;br&gt;&lt;b&gt;Out:&lt;/b&gt; mapUrl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="720" width="160" height="80" as="geometry" />
        </mxCell>
        
        <!-- 9. Final Output -->
        <mxCell id="n_end" value="ApiResponse(200)&lt;br&gt;&lt;b&gt;Sends JSON:&lt;/b&gt; location,&lt;br&gt;weather, mapUrl,&lt;br&gt;suggestions, paths" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="770" y="870" width="100" height="80" as="geometry" />
        </mxCell>

        <!-- Edges -->
